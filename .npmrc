# =============================================================================
#  .npmrc — Global npm configuration
#  Location: ~/.npmrc
# =============================================================================

# Lock exact versions — prevents "works on my machine" issues
save-exact=true

# Default to using the lockfile
package-lock=true

# Suppress the donation/funding messages
fund=false

# Suppress the audit warning on every install (run `npm audit` manually)
audit=false

# Auto-approve peer dependency installation (npm 7+)
legacy-peer-deps=false

# Engine strictness — fail if Node version doesn't match engines field
engine-strict=true

# If you use a private registry (e.g., Artifactory, Verdaccio):
# registry=https://registry.npmjs.org/
# @yourscope:registry=https://your-private-registry.com/
